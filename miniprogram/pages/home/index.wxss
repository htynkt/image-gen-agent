/* 主页：弹性布局 + 紫色主题 + 瀑布流 */
.home {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: 140rpx;        /* 给自定义 tabBar 留空间 */
}

/* 顶部 header（紫色渐变）*/
.header { padding: 24rpx 24rpx 30rpx; }
.search { display: flex; align-items: center; gap: 16rpx; }
.search-input {
  flex: 1; background: rgba(255,255,255,0.92); border-radius: 40rpx;
  padding: 18rpx 28rpx; font-size: 28rpx; color: #333;
}
.search-btn {
  width: 68rpx; height: 68rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25); color: #fff;
  text-align: center; line-height: 68rpx; font-size: 30rpx;
}

/* 分类导航 */
.cats { white-space: nowrap; padding: 20rpx 16rpx 8rpx; }
.cat {
  display: inline-block; padding: 12rpx 30rpx; margin-right: 14rpx;
  background: #fff; border-radius: 30rpx; font-size: 27rpx; color: #666;
  box-shadow: 0 2rpx 8rpx rgba(60,40,120,0.05);
}
.cat.active {
  background: #7c5cff; color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(124,92,255,0.35);
}

/* 瀑布流双列：每行两张，适配屏幕宽度（两列各 50% 减半个间距，中间留 16rpx）*/
.waterfall {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
}
.col {
  width: calc(50% - 8rpx);          /* 每列固定占一半，确保每行两张 */
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.card {
  position: relative; background: #fff; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(60,40,120,0.06);
}
.img { width: 100%; display: block; }
.fav {
  position: absolute; top: 14rpx; right: 14rpx;
  background: rgba(0,0,0,0.4); color: #fff;
  width: 52rpx; height: 52rpx; border-radius: 50%;
  text-align: center; line-height: 52rpx; font-size: 28rpx;
}
.fav.liked { background: rgba(255,80,80,0.92); }
.title { padding: 14rpx 18rpx 18rpx; font-size: 25rpx; color: #555; }

.tip { text-align: center; color: #9aa0a6; padding: 60rpx; font-size: 26rpx; }
