.mine { padding: 20rpx; padding-bottom: 140rpx; }

/* 用户信息卡（紫色渐变）*/
.profile-card {
  display: flex; align-items: center; gap: 24rpx;
  background: linear-gradient(135deg, #a78bfa, #7c5cff);
  border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(124,92,255,0.28);
}
.avatar-pick { padding: 0; width: 50rpx; height: 124rpx; border-radius: 50%; background: rgba(255,255,255,0.3); line-height: 124rpx; overflow: hidden; }
.avatar-pick::after { border: none; }
.avatar-img { width: 124rpx; height: 124rpx; border-radius: 50%; }
.avatar-placeholder { width: 124rpx; height: 124rpx; border-radius: 50%; text-align: center; line-height: 124rpx; font-size: 60rpx; color: #fff; }
.profile-info { flex: 1; }
.nickname-input { color: #fff; font-size: 34rpx; font-weight: 600; }
.oid { font-size: 22rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; }
.save-profile { display: inline-block; margin-top: 14rpx; font-size: 24rpx; color: #7c5cff; background: #fff; padding: 8rpx 28rpx; border-radius: 22rpx; }

.section-title { font-size: 28rpx; font-weight: 600; margin: 24rpx 8rpx 16rpx; }
.grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.grid-img { width: calc((100% - 24rpx) / 3); height: 220rpx; border-radius: 12rpx; background: #eee; }
.empty { text-align: center; color: #999; padding: 80rpx 40rpx; font-size: 26rpx; line-height: 1.8; }
