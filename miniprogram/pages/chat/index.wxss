/* AI 问答页：宽度自适应 + 头像 + 气泡 */
.chat {
  display: flex; flex-direction: column;
  height: 100vh; padding-bottom: calc(120rpx + env(safe-area-inset-bottom));   /* 输入框位置：数值越大越往上；含安全区不被 tabBar 遮 */
  box-sizing: border-box;
}

/* 消息列表 */
.messages { flex: 1; padding: 20rpx; box-sizing: border-box; }
.msg { display: flex; margin-bottom: 28rpx; align-items: flex-start; width: 100%; box-sizing: border-box; }
.msg.user { flex-direction: row-reverse; }   /* 用户消息头像在右 */

/* 头像 */
.avatar { width: 76rpx; height: 76rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; overflow: hidden; }
.avatar.ai { margin-right: 16rpx; background: #ede9fe; }
.avatar.me { margin-left: 16rpx; background: #e0eaff; }
.avatar-img { width: 76rpx; height: 76rpx; }
.avatar-emoji { font-size: 42rpx; }

/* 气泡（宽度自适应：最多占满除头像外的空间）*/
.bubble { max-width: calc(100% - 92rpx); }   /* 76 头像 + 16 间距 */
.msg.agent .text { background: #fff; border: 1rpx solid #eee; border-radius: 4rpx 20rpx 20rpx 20rpx; }
.msg.user .text { background: #7c5cff; color: #fff; border-radius: 20rpx 4rpx 20rpx 20rpx; }
.text {
  display: inline-block; padding: 20rpx 24rpx;
  font-size: 29rpx; line-height: 1.55; white-space: pre-wrap; word-break: break-word;
}
.loading-text { color: #999; background: #fff; border: 1rpx solid #eee; border-radius: 4rpx 20rpx 20rpx 20rpx; }

/* 消息里的图片 */
.images { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 14rpx; }
.img-wrap { display: flex; flex-direction: column; align-items: center; }
.msg-img { width: 200rpx; height: 200rpx; border-radius: 12rpx; background: #eee; }
.save { font-size: 22rpx; color: #7c5cff; margin-top: 6rpx; }

/* 设置微信头像 */
.avatar-tip { padding: 4rpx 24rpx; text-align: center; }
.avatar-btn { font-size: 24rpx; color: #7c5cff; background: transparent; display: inline-block; padding: 0 16rpx; line-height: 1.8; }
.avatar-btn::after { border: none; }

/* 预览 + 输入区 */
.preview { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 20rpx; background: #fff; border-top: 1rpx solid #eee; }
.preview-img { width: 80rpx; height: 80rpx; border-radius: 8rpx; }
.clear { background: #ccc; color: #fff; width: 36rpx; height: 36rpx; border-radius: 50%; text-align: center; line-height: 36rpx; font-size: 26rpx; }

.input-area { display: flex; gap: 12rpx; padding: 16rpx 20rpx; background: #fff; border-top: 1rpx solid #eee; align-items: center; }
.upload { font-size: 44rpx; }
.input { flex: 1; background: #f5f5f7; border-radius: 32rpx; padding: 18rpx 24rpx; font-size: 28rpx; }
.send-btn { background: #7c5cff; color: #fff; font-size: 28rpx; padding: 18rpx 30rpx; border-radius: 12rpx; }
.send-btn.disabled { background: #aaa; }
